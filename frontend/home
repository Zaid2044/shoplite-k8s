<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ShopLite</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #f5f1ed 0%, #eef5f0 100%);
            color: #2d3436;
            min-height: 100vh;
        }

        /* Navigation */
        nav {
            background: rgba(255, 255, 255, 0.95);
            padding: 20px 60px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(200, 180, 170, 0.2);
        }

        .logo {
            font-size: 28px;
            font-weight: 700;
            letter-spacing: -0.5px;
            color: #2d3436;
            background: linear-gradient(135deg, #8b9d83 0%, #b08968 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .cart-btn {
            font-size: 28px;
            cursor: pointer;
            text-decoration: none;
            color: #8b9d83;
            transition: transform 0.3s ease, color 0.3s ease;
            position: relative;
        }

        .cart-btn:hover {
            transform: scale(1.1);
            color: #b08968;
        }

        /* Hero Section */
        .hero {
            text-align: center;
            padding: 80px 40px;
            max-width: 800px;
            margin: 0 auto;
            position: relative;
        }

        .hero h1 {
            font-size: 52px;
            font-weight: 700;
            color: #2d3436;
            margin-bottom: 12px;
            letter-spacing: -1px;
            line-height: 1.2;
        }

        .hero p {
            font-size: 18px;
            color: #6b7280;
            font-weight: 300;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }

        .hero .subtitle {
            font-size: 14px;
            color: #a0a9a0;
            margin-top: 20px;
        }

        /* Products Section */
        .products-wrapper {
            padding: 20px 60px 80px;
        }

        .products {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 32px;
            max-width: 1400px;
            margin: 0 auto;
        }

        /* Card Styles */
        .card {
            background: white;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            flex-direction: column;
            height: 100%;
        }

        .card:hover {
            transform: translateY(-8px);
            box-shadow: 0 12px 32px rgba(0, 0, 0, 0.12);
        }

        .card-image {
            width: 100%;
            height: 240px;
            object-fit: cover;
            background: linear-gradient(135deg, #f0ebe6 0%, #e8f0ed 100%);
            position: relative;
            overflow: hidden;
        }

        .card-image:hover {
            transform: scale(1.05);
        }

        .content {
            padding: 28px 24px;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
        }

        .content h2 {
            font-size: 18px;
            font-weight: 600;
            color: #2d3436;
            margin-bottom: 12px;
            line-height: 1.4;
        }

        .price {
            color: #b08968;
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .quantity {
            color: #9ca3af;
            font-size: 13px;
            font-weight: 500;
            letter-spacing: 0.3px;
            margin-bottom: 20px;
        }

        button {
            width: 100%;
            padding: 14px;
            border: none;
            background: linear-gradient(135deg, #8b9d83 0%, #a8b59e 100%);
            color: white;
            font-weight: 600;
            border-radius: 12px;
            cursor: pointer;
            font-size: 14px;
            letter-spacing: 0.5px;
            transition: all 0.3s ease;
            margin-top: auto;
            text-transform: uppercase;
        }

        button:hover {
            background: linear-gradient(135deg, #7a8c72 0%, #97a48d 100%);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(139, 157, 131, 0.3);
        }

        button:active {
            transform: translateY(0);
        }

        /* Decorative Elements */
        .decoration {
            position: absolute;
            pointer-events: none;
            opacity: 0.3;
        }

        @media (max-width: 768px) {
            nav {
                padding: 16px 20px;
            }

            .logo {
                font-size: 24px;
            }

            .hero {
                padding: 50px 20px;
            }

            .hero h1 {
                font-size: 36px;
            }

            .hero p {
                font-size: 16px;
            }

            .products-wrapper {
                padding: 20px;
            }

            .products {
                grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
                gap: 20px;
            }

            .content {
                padding: 20px;
            }

            button {
                padding: 12px;
                font-size: 13px;
            }
        }
    </style>
</head>
<body>

    <nav>
        <div class="logo">ShopLite</div>
        <a href="/cart" class="cart-btn">🛒</a>
    </nav>

    <section class="hero">
        <h1>Limited Time Offer</h1>
        <p>Discover Our Exclusive Collection</p>
        <p class="subtitle">Premium products curated just for you</p>
    </section>

    <section class="products-wrapper">
        <div class="products" id="products"></div>
    </section>

    <script>
        async function loadProducts() {
            const response = await fetch("/api/products")

            const products = await response.json()

            const productsContainer = document.getElementById("products")

            productsContainer.innerHTML = ""

            products.forEach(product => {
                const card = document.createElement("div")

                card.className = "card"

                card.innerHTML = `
                    <img src="${product.image}" class="card-image" alt="${product.name}" />

                    <div class="content">
                        <h2>${product.name}</h2>

                        <p class="price">₹${product.price}</p>

                        <p class="quantity">
                            Available: ${product.quantity}
                        </p>

                        <button onclick='addToCart(${JSON.stringify(product)})'>
                            Add To Cart
                        </button>
                    </div>
                `

                productsContainer.appendChild(card)
            })
        }

        async function addToCart(product) {
            await fetch("/api/cart", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(product)
            })

            alert("Added to cart")
        }

        loadProducts()
    </script>

</body>
</html>